# .gitignore
# Specifies intentionally untracked files that Git should ignore

# ============================================
# Python-specific ignores
# ============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# PyCharm
.idea/

# VS Code
.vscode/

# ============================================
# Database files (SQLite)
# ============================================
# Local SQLite database files should not be committed
# Production data is in Docker volumes
*.db
*.sqlite
*.sqlite3
*.db-journal

# ============================================
# Environment variables
# ============================================
# Never commit sensitive environment variables
.env
.env.local
.env.*.local

# ============================================
# Docker-specific ignores
# ============================================
# Docker volumes data should not be tracked

# ============================================
# OS-specific files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
