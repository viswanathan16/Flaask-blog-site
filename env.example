# .env.example
# Environment variables configuration template
# Copy this file to .env and customize values as needed

# ============================================
# NOTE: This Flask blog project works without
# any environment variables. This file is 
# included as a best practice template.
# ============================================

# Flask Configuration (Optional)
# Uncomment and modify if you want to customize Flask behavior
# FLASK_ENV=development
# FLASK_DEBUG=1

# Application Settings (Optional)
# FLASK_APP=app.py
# FLASK_RUN_HOST=0.0.0.0
# FLASK_RUN_PORT=5000

# Database Path (Already configured in app.py)
# DATABASE=/data/blog.db

# ============================================
# If you add authentication or external APIs
# in the future, add those secrets here:
# ============================================
# SECRET_KEY=your-secret-key-here
# API_KEY=your-api-key-here
